# ---------------------------------------------------------------------------
# Conduit Test Framework — environment configuration
# ---------------------------------------------------------------------------
# Copy this file to .env and adjust values for your local setup.
#   cp .env.example .env
#
# .env is git-ignored. Never commit real values.
# ---------------------------------------------------------------------------

# Base URL for the Conduit UI (used by Playwright's baseURL)
BASE_URL=http://localhost:4101

# Base URL for the Conduit REST API (used by ApiClient)
API_URL=http://localhost:3000/api
